{
  "info": {
    "title": "Eventpop Public API",
    "description": "Integrate with Eventpop to build event management tools, ticket validation apps, and user experiences. Supports OAuth 2.0 for secure access to events, tickets, and user data.",
    "contact": {
      "name": "Eventpop Developer Team",
      "url": "https://docs.eventpop.me"
    },
    "version": "0.0.1"
  },
  "swagger": "2.0",
  "produces": [
    "application/xml",
    "application/json",
    "application/octet-stream",
    "text/plain"
  ],
  "securityDefinitions": {
    "user_token": {
      "type": "oauth2",
      "flow": "accessCode",
      "authorizationUrl": "https://www.eventpop.me/oauth/authorize",
      "tokenUrl": "https://www.eventpop.me/oauth/token",
      "scopes": {
        "public": "Access user profile and user-owned resources (orders, tickets)",
        "organizer": "Access organizer resources and ticket management (requires user-organizer association)"
      }
    },
    "application_token": {
      "type": "oauth2",
      "flow": "application",
      "tokenUrl": "https://www.eventpop.me/oauth/token",
      "scopes": {
        "public": "Access organizer resources (application owner only)"
      }
    }
  },
  "host": "www.eventpop.me",
  "basePath": "/api/public",
  "tags": [
    {
      "name": "Ticket Management",
      "description": "Operations about Ticket Managements"
    },
    { "name": "Info", "description": "API version and status information" },
    {
      "name": "User Profile",
      "description": "User authentication and profile data (User Token: public scope)"
    },
    {
      "name": "User Resources",
      "description": "User-owned orders and tickets (User Token: public scope)"
    },
    {
      "name": "Organizer Resources",
      "description": "Organizer-owned events (Application Token or User Token: organizer scope)"
    }
  ],
  "paths": {
    "/organizers/{organizer_id}/tickets": {
      "get": {
        "summary": "List authenticated user's tickets",
        "description": "Returns a paginated list of tickets belonging to the authenticated user for events within the specified organizer. Requires User Access Token with `public` scope. Only returns tickets for events owned by the specified organizer.",
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "query",
            "name": "access_token",
            "description": "OAuth Token (alternative to Authorization header)",
            "type": "string",
            "required": false
          },
          {
            "in": "query",
            "name": "order_by",
            "type": "string",
            "default": "id",
            "enum": ["id", "created_at", "updated_at", "used_at"],
            "required": false
          },
          {
            "in": "query",
            "name": "order",
            "type": "string",
            "default": "asc",
            "enum": ["asc", "desc"],
            "required": false
          },
          {
            "in": "query",
            "name": "page",
            "type": "integer",
            "format": "int32",
            "default": 1,
            "required": false
          },
          {
            "in": "query",
            "name": "per_page",
            "type": "integer",
            "format": "int32",
            "default": 10,
            "required": false
          },
          {
            "in": "path",
            "name": "organizer_id",
            "type": "integer",
            "format": "int32",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Get user's tickets",
            "schema": { "$ref": "#/definitions/PublicAPI_Entities_Ticket" }
          },
          "401": {
            "description": "Unauthorized - Invalid user token or organizer mismatch"
          },
          "403": { "description": "Forbidden - Missing public scope" }
        },
        "tags": ["User Resources"],
        "operationId": "getOrganizersOrganizerIdTickets"
      }
    },
    "/organizers/{organizer_id}/events/{event_id}/tickets/invalidate": {
      "post": {
        "summary": "Revoke/invalidate a ticket",
        "description": "Marks a ticket as revoked. Used when external system cancels/refunds a ticket.",
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "parameters": [
          {
            "in": "formData",
            "name": "ticket_id",
            "description": "Ticket ID",
            "type": "integer",
            "format": "int32",
            "required": false
          },
          {
            "in": "formData",
            "name": "reference_code",
            "description": "Ticket reference code",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "reason",
            "description": "Reason for revoking the ticket",
            "type": "string",
            "required": false
          },
          {
            "in": "path",
            "name": "organizer_id",
            "type": "integer",
            "format": "int32",
            "required": true
          },
          {
            "in": "path",
            "name": "event_id",
            "type": "integer",
            "format": "int32",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Invalidate ticket",
            "schema": {
              "$ref": "#/definitions/PublicAPI_Entities_TicketResponse"
            }
          },
          "401": { "description": "Unauthorized - Invalid token" },
          "403": {
            "description": "Forbidden - Application not owned by organizer"
          },
          "404": { "description": "Ticket not found" },
          "422": {
            "description": "Unprocessable - Ticket already revoked or used"
          }
        },
        "tags": ["Ticket Management"],
        "operationId": "postOrganizersOrganizerIdEventsEventIdTicketsInvalidate"
      }
    },
    "/organizers/{organizer_id}/events/{event_id}/tickets": {
      "get": {
        "summary": "Get all tickets for an event with pagination and filtering",
        "description": "Returns a paginated list of tickets for the specified event. Supports filtering by status, ticket type, email, phone, and date ranges. Use `email` filter to check if a specific attendee has registered for the event. Requires User Access Token with `organizer` scope.",
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "description": "Filter by status (comma-separated, e.g., \"active,used\")",
            "type": "string",
            "required": false
          },
          {
            "in": "query",
            "name": "ticket_type_id",
            "description": "Filter by ticket type ID",
            "type": "integer",
            "format": "int32",
            "required": false
          },
          {
            "in": "query",
            "name": "email",
            "description": "Filter by attendee email (contains, case-insensitive). Sensitive: passing PII in URLs may be captured by access logs, proxies, and browser history. Prefer transmitting over TLS only, avoid logging request URLs, and rotate logs that may contain this value.",
            "type": "string",
            "required": false,
            "x-sensitive": true
          },
          {
            "in": "query",
            "name": "phone",
            "description": "Filter by attendee phone number (contains). Sensitive: passing PII in URLs may be captured by access logs, proxies, and browser history. Prefer transmitting over TLS only, avoid logging request URLs, and rotate logs that may contain this value.",
            "type": "string",
            "required": false,
            "x-sensitive": true
          },
          {
            "in": "query",
            "name": "updated_before",
            "description": "Filter tickets updated before this time (ISO 8601)",
            "type": "string",
            "format": "date-time",
            "required": false
          },
          {
            "in": "query",
            "name": "updated_after",
            "description": "Filter tickets updated after this time (ISO 8601)",
            "type": "string",
            "format": "date-time",
            "required": false
          },
          {
            "in": "query",
            "name": "max_id",
            "description": "Tickets with ID less than this value (for deep pagination)",
            "type": "integer",
            "format": "int32",
            "required": false
          },
          {
            "in": "query",
            "name": "min_id",
            "description": "Tickets with ID greater than this value (for deep pagination)",
            "type": "integer",
            "format": "int32",
            "required": false
          },
          {
            "in": "query",
            "name": "order_by",
            "type": "string",
            "default": "id",
            "enum": ["id", "created_at", "updated_at", "used_at", "reference_code"],
            "required": false
          },
          {
            "in": "query",
            "name": "order",
            "type": "string",
            "default": "asc",
            "enum": ["asc", "desc"],
            "required": false
          },
          {
            "in": "query",
            "name": "page",
            "type": "integer",
            "format": "int32",
            "default": 1,
            "required": false
          },
          {
            "in": "query",
            "name": "per_page",
            "type": "integer",
            "format": "int32",
            "default": 10,
            "required": false
          },
          {
            "in": "path",
            "name": "organizer_id",
            "type": "integer",
            "format": "int32",
            "required": true
          },
          {
            "in": "path",
            "name": "event_id",
            "type": "integer",
            "format": "int32",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "List all tickets in event",
            "schema": {
              "$ref": "#/definitions/PublicAPI_Entities_TicketsListResponse"
            }
          },
          "401": { "description": "Unauthorized" },
          "403": {
            "description": "Forbidden - Organizer scope required or application not owned by organizer"
          },
          "404": { "description": "Event not found" }
        },
        "tags": ["Organizer Resources"],
        "operationId": "getOrganizersOrganizerIdEventsEventIdTickets"
      },
      "post": {
        "summary": "Create a new ticket for an event",
        "description": "Creates a ticket via API for external ticketing systems. Requires User Access Token with organizer scope.",
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "parameters": [
          {
            "in": "formData",
            "name": "ticket_type_id",
            "description": "Ticket type ID",
            "type": "integer",
            "format": "int32",
            "required": true
          },
          {
            "in": "formData",
            "name": "firstname",
            "description": "First name",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "lastname",
            "description": "Last name",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "email",
            "description": "Email address",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "phone",
            "description": "Phone number",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "external_id",
            "description": "External ticket ID for idempotency",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "reference_code",
            "description": "Custom reference code (auto-generated if not provided)",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "suppress_notifications",
            "description": "Suppress email notifications",
            "type": "boolean",
            "default": false,
            "required": false
          },
          {
            "in": "path",
            "name": "organizer_id",
            "type": "integer",
            "format": "int32",
            "required": true
          },
          {
            "in": "path",
            "name": "event_id",
            "type": "integer",
            "format": "int32",
            "required": true
          }
        ],
        "responses": {
          "201": {
            "description": "Create ticket via API",
            "schema": {
              "$ref": "#/definitions/PublicAPI_Entities_TicketResponse"
            }
          },
          "400": { "description": "Bad Request - Invalid parameters" },
          "401": { "description": "Unauthorized - Invalid token" },
          "403": {
            "description": "Forbidden - Application not owned by organizer"
          },
          "404": { "description": "Event or ticket type not found" },
          "409": {
            "description": "Conflict - Duplicate external_id or reference_code"
          },
          "422": { "description": "Unprocessable - API ticket quota exceeded" }
        },
        "tags": ["Ticket Management"],
        "operationId": "postOrganizersOrganizerIdEventsEventIdTickets"
      }
    },
    "/organizers/{organizer_id}/orders": {
      "get": {
        "summary": "List authenticated user's orders",
        "description": "Returns a paginated list of orders belonging to the authenticated user for events within the specified organizer. Requires User Access Token with `public` scope. Only returns orders for events owned by the specified organizer.",
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "query",
            "name": "access_token",
            "description": "OAuth Token (alternative to Authorization header)",
            "type": "string",
            "required": false
          },
          {
            "in": "query",
            "name": "order_by",
            "type": "string",
            "default": "id",
            "enum": ["id", "created_at", "paid_at", "updated_at"],
            "required": false
          },
          {
            "in": "query",
            "name": "order",
            "type": "string",
            "default": "asc",
            "enum": ["asc", "desc"],
            "required": false
          },
          {
            "in": "query",
            "name": "page",
            "type": "integer",
            "format": "int32",
            "default": 1,
            "required": false
          },
          {
            "in": "query",
            "name": "per_page",
            "type": "integer",
            "format": "int32",
            "default": 10,
            "required": false
          },
          {
            "in": "path",
            "name": "organizer_id",
            "type": "integer",
            "format": "int32",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Get user's orders",
            "schema": { "$ref": "#/definitions/PublicAPI_Entities_Order" }
          },
          "401": {
            "description": "Unauthorized - Invalid user token or organizer mismatch"
          },
          "403": { "description": "Forbidden - Missing public scope" }
        },
        "tags": ["User Resources"],
        "operationId": "getOrganizersOrganizerIdOrders"
      }
    },
    "/organizers/{organizer_id}/events": {
      "get": {
        "summary": "List events for an organizer",
        "description": "Returns a paginated list of events owned by the specified organizer. Requires Application Access Token (the application must be owned by this organizer). Supports filtering via `q` parameter and sorting.",
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "query",
            "name": "access_token",
            "description": "OAuth Token (alternative to Authorization header)",
            "type": "string",
            "required": false
          },
          {
            "in": "query",
            "name": "page",
            "type": "integer",
            "format": "int32",
            "default": 1,
            "required": false
          },
          {
            "in": "query",
            "name": "per_page",
            "type": "integer",
            "format": "int32",
            "default": 10,
            "required": false
          },
          {
            "in": "query",
            "name": "order_by",
            "type": "string",
            "default": "id",
            "enum": ["id", "created_at", "updated_at", "start_at", "end_at"],
            "required": false
          },
          {
            "in": "query",
            "name": "order",
            "type": "string",
            "default": "asc",
            "enum": ["asc", "desc"],
            "required": false
          },
          {
            "in": "path",
            "name": "organizer_id",
            "type": "integer",
            "format": "int32",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Get organizer's events",
            "schema": { "$ref": "#/definitions/PublicAPI_Entities_Event" }
          },
          "401": {
            "description": "Unauthorized - Invalid token or organizer mismatch"
          },
          "403": {
            "description": "Forbidden - Application not owned by this organizer"
          }
        },
        "tags": ["Organizer Resources"],
        "operationId": "getOrganizersOrganizerIdEvents"
      }
    },
    "/info": {
      "get": {
        "summary": "Get API version and status",
        "description": "Returns the current API version. No authentication required.",
        "produces": ["application/json"],
        "responses": { "200": { "description": "Get API version and status" } },
        "tags": ["Info"],
        "operationId": "getInfo"
      }
    },
    "/me": {
      "get": {
        "summary": "Get current user information",
        "description": "Returns profile information for the authenticated user. Requires User Access Token with `public` scope. Rate limited to 10 requests per minute.",
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "description": "Bearer token (e.g., \"Bearer YOUR_ACCESS_TOKEN\")",
            "type": "string",
            "required": false
          },
          {
            "in": "query",
            "name": "access_token",
            "description": "OAuth Token (alternative to Authorization header)",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Get authenticated user profile",
            "schema": { "$ref": "#/definitions/PublicAPI_Entities_User" }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing access token"
          }
        },
        "tags": ["User Profile"],
        "operationId": "getMe"
      }
    },
    "/tickets/search": {
      "get": {
        "summary": "Find a specific ticket",
        "description": "Searches for a ticket by event ID and reference code within the organizer's events. Requires Application Access Token (the application must be owned by the event's organizer). Useful for ticket validation and check-in systems.",
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "query",
            "name": "event_id",
            "description": "Event ID",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "reference_code",
            "description": "Ticket reference code (e.g., \"ABC123\")",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "access_token",
            "description": "OAuth Token (alternative to Authorization header)",
            "type": "string",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Search ticket by reference code",
            "schema": { "$ref": "#/definitions/PublicAPI_Entities_Ticket" }
          },
          "401": { "description": "Unauthorized - Invalid token" },
          "404": {
            "description": "Ticket not found - Invalid event ID, reference code, or organizer mismatch"
          }
        },
        "tags": ["User Resources"],
        "operationId": "getTicketsSearch"
      }
    }
  },
  "definitions": {
    "PublicAPI_Entities_Ticket": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int32",
          "description": "Unique ticket identifier"
        },
        "order_id": {
          "type": "integer",
          "format": "int32",
          "description": "ID of the order this ticket belongs to"
        },
        "event_id": {
          "type": "integer",
          "format": "int32",
          "description": "ID of the event this ticket is for"
        },
        "status": {
          "type": "string",
          "description": "Ticket status (e.g., \"active\", \"used\", \"revoked\")"
        },
        "firstname": {
          "type": "string",
          "description": "Ticket holder first name"
        },
        "lastname": {
          "type": "string",
          "description": "Ticket holder last name"
        },
        "phone": {
          "type": "string",
          "description": "Ticket holder phone number"
        },
        "email": {
          "type": "string",
          "description": "Ticket holder email address"
        },
        "reference_code": {
          "type": "string",
          "description": "Unique reference code for ticket validation (e.g., \"ABC123\")"
        },
        "kind": {
          "type": "string",
          "description": "Ticket kind (e.g., \"normal\", \"external\")"
        },
        "external_id": {
          "type": "string",
          "description": "External system identifier for idempotency"
        },
        "revoke_note": {
          "type": "string",
          "description": "Note explaining why ticket was revoked"
        },
        "ticket_type": {
          "$ref": "#/definitions/TicketType_PartnerEntity",
          "description": "Ticket type information including name and price"
        },
        "price_label": {
          "type": "string",
          "description": "Ticket price label (formatted price, \"Free\", complimentary note, or pack pricing)"
        },
        "forms": {
          "type": "array",
          "description": "Custom form field responses for this ticket"
        },
        "created_at": {
          "type": "string",
          "description": "Ticket creation timestamp (ISO 8601 format)"
        },
        "updated_at": {
          "type": "string",
          "description": "Last update timestamp (ISO 8601 format)"
        },
        "used_at": {
          "type": "string",
          "description": "Check-in timestamp (ISO 8601 format), null if not used"
        },
        "registered_at": {
          "type": "string",
          "description": "Registration timestamp (ISO 8601 format), null if not registered"
        }
      },
      "description": "PublicAPI_Entities_Ticket model"
    },
    "TicketType_PartnerEntity": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "price_satangs": { "type": "string" },
        "kind": { "type": "string" }
      }
    },
    "PublicAPI_Entities_TicketResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "Operation success status"
        },
        "idempotent": {
          "type": "boolean",
          "description": "Whether this was an idempotent response"
        },
        "ticket": {
          "$ref": "#/definitions/PublicAPI_Entities_Ticket",
          "description": "Created or retrieved ticket"
        }
      },
      "description": "PublicAPI_Entities_TicketResponse model"
    },
    "PublicAPI_Entities_TicketsListResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "Operation success status"
        },
        "tickets": {
          "type": "array",
          "items": { "$ref": "#/definitions/PublicAPI_Entities_Ticket" },
          "description": "List of tickets"
        },
        "count": {
          "type": "integer",
          "format": "int32",
          "description": "Number of tickets in current page"
        },
        "total": {
          "type": "integer",
          "format": "int32",
          "description": "Total number of tickets matching query"
        },
        "page": {
          "type": "integer",
          "format": "int32",
          "description": "Current page number"
        },
        "per_page": {
          "type": "integer",
          "format": "int32",
          "description": "Number of items per page"
        }
      },
      "description": "Paginated list of tickets"
    },
    "PublicAPI_Entities_Order": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int32",
          "description": "Unique order identifier"
        },
        "status": {
          "type": "string",
          "description": "Order status (e.g., \"paid\", \"pending\", \"cancelled\")"
        },
        "buyer_firstname": {
          "type": "string",
          "description": "Buyer first name"
        },
        "buyer_lastname": {
          "type": "string",
          "description": "Buyer last name"
        },
        "buyer_email": {
          "type": "string",
          "description": "Buyer email address"
        },
        "buyer_phone": {
          "type": "string",
          "description": "Buyer full phone number as stored"
        },
        "buyer_phone_country": {
          "type": "string",
          "description": "Buyer phone country ISO code (e.g., \"TH\", \"US\")"
        },
        "buyer_phone_country_code": {
          "type": "string",
          "description": "Buyer phone country dialing code without \"+\" (e.g., \"66\", \"1\")"
        },
        "buyer_phone_local": {
          "type": "string",
          "description": "Buyer phone in national format without country code"
        },
        "event_id": {
          "type": "integer",
          "format": "int32",
          "description": "ID of the event this order is for"
        },
        "forms": {
          "type": "array",
          "description": "Custom form field responses for this order"
